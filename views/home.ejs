}
geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
const particles = new THREE.Points(geometry, new THREE.PointsMaterial({ color: 0x50d8f7, size: 2 }));
scene.add(particles);
camera.position.z = 1000;

