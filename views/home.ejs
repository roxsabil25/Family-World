<div id="videoModal" class="fixed inset-0 z-[100] hidden bg-black/90 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300">
    
    <button onclick="closeModal()" class="absolute top-5 right-5 text-white text-4xl hover:text-gray-400 z-[110]">
        &times;
    </button>

    <div class="relative w-full flex items-center justify-center">
        <video id="modalVideo" class="max-h-[75vh] w-auto rounded-lg shadow-2xl" controls autoplay>
            <source src="" type="video/mp4">
            Your browser does not support the video tag.
        </video>
    </div>

    <div class="absolute inset-0 -z-10" onclick="closeModal()"></div>
</div>


<script>
    const modal = document.getElementById('videoModal');
const modalVideo = document.getElementById('modalVideo');

function openModal(videoSrc) {
    // Modal show kora
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Video source set kora ebong play kora
    modalVideo.src = videoSrc;
    modalVideo.muted = false; // Boro obosthay sound thakbe
    modalVideo.play();
    
    // Background scroll bondho kora
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    // Modal hide kora
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    
    // Video pause kora ebong source clean kora (jeno sound theme jay)
    modalVideo.pause();
    modalVideo.src = "";
    
    // Background scroll abr chalu kora
    document.body.style.overflow = 'auto';
}

// Keyboard er 'Esc' button chaple jeno bondho hoy
document.addEventListener('keydown', (e) => {
    if (e.key === "Escape") closeModal();
});
</script>
