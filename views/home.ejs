<script>
    // Three.js Scene Setup with Unique Variable Names
    const luxHeroScene = new THREE.Scene();
    const luxHeroCamera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const luxHeroRenderer = new THREE.WebGLRenderer({ 
        canvas: document.getElementById('bg-canvas'), 
        alpha: true, 
        antialias: true 
    });
    
    luxHeroRenderer.setSize(window.innerWidth, window.innerHeight);
    luxHeroRenderer.setPixelRatio(window.devicePixelRatio);

    // Grid System Configuration
    const wavePointCount = 50;
    const wavePointSpacing = 15;
    const waveGeometry = new THREE.BufferGeometry();
    const waveVertexPositions = new Float32Array(wavePointCount * wavePointCount * 3);

    // Building the Particle Grid
    for (let row = 0; row < wavePointCount; row++) {
        for (let col = 0; col < wavePointCount; col++) {
            const vertexIndex = (row * wavePointCount + col) * 3;
            waveVertexPositions[vertexIndex] = (row - wavePointCount / 2) * wavePointSpacing;     // x
            waveVertexPositions[vertexIndex + 1] = 0;                                           // y
            waveVertexPositions[vertexIndex + 2] = (col - wavePointCount / 2) * wavePointSpacing; // z
        }
    }

    waveGeometry.setAttribute('position', new THREE.BufferAttribute(waveVertexPositions, 3));
    
    // Luxury Particle Styling
    const waveMaterial = new THREE.PointsMaterial({ 
        color: 0x4a5568, 
        size: 2, 
        transparent: true, 
        opacity: 0.5 
    });
    
    const waveMeshPoints = new THREE.Points(waveGeometry, waveMaterial);
    luxHeroScene.add(waveMeshPoints);

    luxHeroCamera.position.set(0, 200, 400);
    luxHeroCamera.lookAt(0, 0, 0);

    // Animation Timing & Frame Logic
    let luxClock = new THREE.Clock();

    function animateLuxWave() {
        requestAnimationFrame(animateLuxWave);
        let elapsedTime = luxClock.getElapsedTime();
        
        const positionBuffer = waveGeometry.attributes.position;
        for (let r = 0; r < wavePointCount; r++) {
            for (let c = 0; c < wavePointCount; c++) {
                const currentIdx = (r * wavePointCount + c) * 3;
                
                // Fetching X and Z to calculate the dynamic Y (Wave Height)
                const currentX = positionBuffer.array[currentIdx];
                const currentZ = positionBuffer.array[currentIdx + 2];
                
                // Advanced Sin/Cos Wave Math
                positionBuffer.array[currentIdx + 1] = 
                    Math.sin(elapsedTime + currentX * 0.05) * 20 + 
                    Math.cos(elapsedTime + currentZ * 0.05) * 20;
            }
        }
        
        positionBuffer.needsUpdate = true;
        luxHeroRenderer.render(luxHeroScene, luxHeroCamera);
    }

    // Initialize Animation
    animateLuxWave();

    // Handling Window Resizing Dynamically
    window.addEventListener('resize', () => {
        luxHeroCamera.aspect = window.innerWidth / window.innerHeight;
        luxHeroCamera.updateProjectionMatrix();
        luxHeroRenderer.setSize(window.innerWidth, window.innerHeight);
    });
</script>





