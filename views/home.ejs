    <style>
        /* Video slider-er scrollbar hide korar jonno */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }


        /* Video hover korle jeno smooth bhabe zoom hoy */
        .video-card:hover video {
            transform: scale(1.05);
        }


        /* CSS দিয়ে আমরা smooth এবং continuous এনিমেশন তৈরি করছি */
        @keyframes slide {
            from { transform: translateX(0); }
            to { transform: translateX(-100%); } /* মোট স্লাইডার কন্টেন্টের সমান বামে যাবে */
        }

        .animate-slide {
            animation: slide 30s linear infinite; /* 30 সেকেন্ড পর পর লুপ হবে */
        }
    </style>
</head>
