    { title: "Healthy Heart Tips", img: "/img/thamble03.jpeg", desc: "Discover the best exercises to keep your heart pumping strong..." },
];

const wrapper = document.getElementById('article-wrapper');
articles.forEach(art => {
    wrapper.innerHTML += `
    <div class="swiper-slide">
        <div class="bg-[#cde9f0] rounded-[30px] p-6 h-full flex flex-col shadow-2xl transform transition-all duration-500 hover:-translate-y-2">
            <img src="${art.img}" class="w-full h-48 md:h-60 object-cover rounded-2xl mb-6 shadow-lg">
            <h3 class="text-2xl font-black text-[#1a2b3c] mb-4">${art.title}</h3>
            <p class="text-gray-700 leading-relaxed mb-6 flex-grow">${art.desc}</p>
            <button class="bg-[#006699] text-white font-bold py-3 px-8 rounded-full w-fit hover:bg-[#004466] transition-colors">
                Learn More
            </button>
        </div>
    </div>`;
});

// 3. Swiper Initialization
const swiper = new Swiper(".articleSwiper", {
