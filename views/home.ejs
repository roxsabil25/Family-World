    <!-- JavaScript - অটো-প্লে এবং ভিডিও পরিবর্তনের জন্য -->
    <script>
        const video = document.getElementById('mainVideo');
        const videoSource = document.getElementById('videoSource');
        const currentTitle = document.getElementById('currentVideoTitle');

        // আপনার ভিডিও এবং তাদের শিরোনামের একটি অ্যারে তৈরি করুন
        const playlist = [
            { src: '/videos/15.mp4', title: '10 Slashing video' },
            { src: '/videos/16.mp4', title: 'Epic Space Journey' },
            { src: '/videos/17.mp4', title: 'Galactic Mysteries Explored' },
            // ... আরও ভিডিও যোগ করুন
        ];

        let currentVideoIndex = 0; // প্রথম ভিডিও থেকে শুরু হবে

        // যখন একটি ভিডিও শেষ হবে, এই ফাংশনটি চলবে
        video.addEventListener('ended', function() {
            // পরবর্তী ভিডিওর ইনডেক্স ঠিক করুন
            currentVideoIndex = (currentVideoIndex + 1) % playlist.length; // শেষ হলে আবার প্রথমে ফিরে যাবে

            // নতুন ভিডিওর সোর্স এবং টাইটেল আপডেট করুন
            changeVideo(playlist[currentVideoIndex].src, playlist[currentVideoIndex].title);
        });

        // ম্যানুয়ালি ভিডিও পরিবর্তন করার ফাংশন (প্লেলিস্ট থেকে ক্লিক করলে)
        function changeVideo(src, title) {
            // ভিডিও সোর্স পরিবর্তন করুন
            videoSource.src = src;
            
            // টাইটেল আপডেট করুন
            currentTitle.textContent = title + " - Playing Now";
            
            // নতুন ভিডিও লোড এবং প্লে করুন
            video.load(); // গুরুত্বপূর্ণ! সোর্স পরিবর্তন করার পর এটি প্রয়োজন
            video.play().catch(error => {
                // কিছু ব্রাউজার অটো-প্লের অনুমতি দেয় না যদি না সেটি muted থাকে।
                console.error("Auto-play failed:", error);
            });
        }
    </script>
</section>




